{
  "name": "@loupedeck-linux/sidecar",
  "version": "0.1.1",
  "description": "Loupedeck Live S Linux controller sidecar",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "main.ts",
  "scripts": {
    "start": "LOG_LEVEL=info tsx main.ts",
    "start:debug": "LOG_LEVEL=debug tsx main.ts",
    "start:prod": "NODE_ENV=production LOG_LEVEL=info node dist/main.js",
    "sidecar": "NODE_ENV=production LOG_LEVEL=info LOUPEDECK_LOG_TO_STDERR=true tsx sidecar.ts",
    "sidecar:prod": "NODE_ENV=production LOG_LEVEL=info LOUPEDECK_LOG_TO_STDERR=true node dist/sidecar.js",
    "dev": "LOG_LEVEL=debug tsx watch main.ts",
    "dev:info": "LOG_LEVEL=info tsx watch main.ts",
    "dev:no-led": "LOG_LEVEL=debug SKIP_LED=true tsx watch main.ts",
    "dev:sidecar": "NODE_ENV=production LOG_LEVEL=debug LOUPEDECK_LOG_TO_STDERR=true tsx watch sidecar.ts",
    "build": "esbuild main.ts sidecar.ts --bundle --platform=node --format=esm --outdir=dist --sourcemap --external:canvas --external:express --external:loupedeck --external:pino --external:pino-pretty --external:chokidar --external:cors --external:zod --external:x11 --external:dbus-next",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dbus-next": "^0.10.2",
    "express": "^5.2.1",
    "loupedeck": "^7.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "typescript-eslint": "^8.62.1"
  }
}
