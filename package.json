{
  "name": "loupedeck-linux",
  "version": "0.1.0",
  "packageManager": "pnpm@11.10.0",
  "description": "Loupedeck Live S Linux controller desktop application",
  "license": "MIT",
  "bin": {
    "loupedeck-linux": "./bin/loupedeck-linux"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm run desktop:dev",
    "build": "pnpm run desktop:build",
    "desktop:dev": "pnpm --filter @loupedeck-linux/desktop run dev",
    "desktop:build": "pnpm --filter @loupedeck-linux/desktop run build",
    "desktop:build:appimage": "pnpm --filter @loupedeck-linux/desktop run build:appimage",
    "build:appimage": "pnpm run desktop:build:appimage",
    "sidecar:start": "pnpm --filter @loupedeck-linux/sidecar run start",
    "sidecar:start:debug": "pnpm --filter @loupedeck-linux/sidecar run start:debug",
    "sidecar:start:prod": "pnpm --filter @loupedeck-linux/sidecar run start:prod",
    "sidecar:dev": "pnpm --filter @loupedeck-linux/sidecar run dev",
    "sidecar:dev:info": "pnpm --filter @loupedeck-linux/sidecar run dev:info",
    "sidecar:dev:no-led": "pnpm --filter @loupedeck-linux/sidecar run dev:no-led",
    "sidecar:dev:sidecar": "pnpm --filter @loupedeck-linux/sidecar run dev:sidecar",
    "sidecar:sidecar": "pnpm --filter @loupedeck-linux/sidecar run sidecar",
    "sidecar:build": "pnpm --filter @loupedeck-linux/sidecar run build",
    "frontend:dev": "pnpm --filter @loupedeck-linux/frontend run dev",
    "frontend:build": "pnpm --filter @loupedeck-linux/frontend run build",
    "frontend:preview": "pnpm --filter @loupedeck-linux/frontend run preview",
    "clean": "rm -rf apps/desktop/sidecar/dist apps/desktop/frontend/dist",
    "test": "vitest run",
    "lint": "pnpm run -r lint",
    "lint:fix": "pnpm run -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "pnpm run -r typecheck",
    "version:sync": "node scripts/sync-version.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "kill": "./scripts/kill-loupedeck.sh",
    "device:doctor": "./scripts/device-doctor.sh",
    "device:setup:udev": "./scripts/setup-udev.sh"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "volta": {
    "node": "22.20.0",
    "npm": "11.4.2"
  }
}
